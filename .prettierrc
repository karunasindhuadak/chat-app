{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "printWidth": 80,
  "jsxSingleQuote": false,
  "endOfLine": "crlf",
  "singleAttributePerLine": true,
  "plugins": []
}
